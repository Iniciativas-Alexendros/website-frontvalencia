# FRONT Valencia — Environment Variables
# Copy this file to .env and fill in values

# CoverManager reservation widget (already public URLs, no secret needed)
PUBLIC_RESERVAS_ES_URL=https://www.covermanager.com/reservation/module_restaurant/restaurante-front-valencia/spanish
PUBLIC_RESERVAS_EN_URL=https://www.covermanager.com/reservation/module_restaurant/restaurante-front-valencia/english

# Meta Pixel ID (optional, gated behind cookie consent)
# PUBLIC_META_PIXEL_ID=

# Metricool (gated behind cookie consent)
# Already loaded from tracker.metricool.com

# Google Maps embed (public embed URL, no API key needed for basic embed)
# PUBLIC_GOOGLE_MAPS_EMBED_URL=
