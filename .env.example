# =========================================================
# FRONT Valencia — Environment Variables (root)
# =========================================================
# Copy this file to `.env` and replace every `<...>` placeholder.
# Do NOT commit the real `.env` file — it's gitignored.
#
# Required secrets (generate with: openssl rand -base64 32):
#   PAYLOAD_SECRET
#   PAYLOAD_PREVIEW_SECRET
#
# Per-deploy-target notes:
#   LOCAL     — Docker Compose (Postgres, Payload, Astro)
#   PREVIEW   — Vercel PR + Railway CMS preview
#   PRODUCTION — Vercel (web) + Railway (cms) + Cloudflare R2 (media)
# =========================================================

# ---------------------------------------
# DATABASE (Postgres)
# ---------------------------------------
# LOCAL: postgresql://frontvalencia:<DB_PASSWORD>@localhost:5432/frontvalencia
# PROD: postgres://user:pass@host:port/db (Railway managed)
DATABASE_URI=postgresql://frontvalencia:changeme@localhost:5432/frontvalencia
DATABASE_DIRECT_URL=

# ---------------------------------------
# PAYLOAD CMS
# ---------------------------------------
# generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace_me_with_openssl_rand_base64_32
# Same secret as Astro PAYLOAD_PREVIEW_SECRET
PAYLOAD_PREVIEW_SECRET=replace_me_with_openssl_rand_base64_32
# Public URL for Payload API (used by Astro to fetch)
PAYLOAD_API_URL=http://localhost:3001/api
# Used inside Payload to construct preview URLs
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ---------------------------------------
# ASTRO WEB
# ---------------------------------------
# Public site URL (used in metadata, sitemap, canonical, OG)
PUBLIC_SITE_URL=http://localhost:4321
# Payload API URL for server-side fetch
PAYLOAD_API_URL=http://localhost:3001/api
# Same as PAYLOAD_PREVIEW_SECRET above
PAYLOAD_PREVIEW_SECRET=replace_me_with_openssl_rand_base64_32

# ---------------------------------------
# CLOUDFLARE R2 (storage de imágenes)
# ---------------------------------------
# Free tier: 10 GB / month, sin egress fees.
# 1) Crear bucket en https://dash.cloudflare.com/?to=/:account/r2
# 2) Generar Access Key en R2 → Manage R2 API Tokens
# 3) Activar public bucket o custom domain
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=frontvalencia-dev
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
# Public URL para servir imágenes via R2 public bucket o custom domain
R2_PUBLIC_URL=https://pub-<bucket>.r2.dev
# Custom domain para producción:
# R2_PUBLIC_URL=https://media.frontvalencia.com

# ---------------------------------------
# EXTERNAL SERVICES (Third-party widgets)
# ---------------------------------------
# CoverManager (ya son URLs públicas, no son secretos)
PUBLIC_RESERVAS_ES_URL=https://www.covermanager.com/reservation/module_restaurant/restaurante-front-valencia/spanish
PUBLIC_RESERVAS_EN_URL=https://www.covermanager.com/reservation/module_restaurant/restaurante-front-valencia/english

# Meta Pixel — opcional, gated bajo cookie consent
# PUBLIC_META_PIXEL_ID=

# Google Maps embed URL — opcional, embed público no requiere API key
# PUBLIC_GOOGLE_MAPS_EMBED_URL=

# ---------------------------------------
# OPTIONAL — Vercel deployment (web)
# ---------------------------------------
# Solo necesario si deployas con Vercel CLI.
# Obtener el token: https://vercel.com/account/tokens
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ---------------------------------------
# OPTIONAL — Railway deployment (cms)
# ---------------------------------------
# Solo necesario si deployas con Railway CLI.
# Obtener el token en: https://railway.app/account/tokens
# RAILWAY_TOKEN=
