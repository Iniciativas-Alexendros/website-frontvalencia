---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header.astro';
import Hero from '../../components/sections/Hero.astro';
import MenuSection from '../../components/sections/MenuSection.astro';
import EspacioSection from '../../components/sections/EspacioSection.astro';
import LocalizacionSection from '../../components/sections/LocalizacionSection.astro';
import ReservasSection from '../../components/sections/ReservasSection.astro';
import ClubBanner from '../../components/sections/ClubBanner.astro';
import Footer from '../../components/sections/Footer.astro';
import CookieConsent from '../../components/islands/CookieConsent';
import { safeGetMenu, safeGetSite } from '../../lib/content';

const menuData = await safeGetMenu('en');
const siteData = await safeGetSite();
const categories = menuData.categories;
const allergenLegend = menuData.allergenLegend ?? [];
---

<BaseLayout
  lang="en"
  title="FRONT | Restaurant & Terrace La Marina de Valencia"
  description="By the sea, next to the Port Clock, in the most brutalist building in Valencia. Mediterranean cuisine, grills, rice, music, cocktails and views."
>
  <Header lang="en" />
  <main id="main-content">
    <Hero lang="en" />
    <MenuSection categories={categories} allergenLegend={allergenLegend} lang="en" />
    <EspacioSection lang="en" />
    <ClubBanner lang="en" />
    <LocalizacionSection lang="en" />
    <ReservasSection lang="en" />
  </main>
  <Footer lang="en" />
  <CookieConsent lang="en" client:idle />
</BaseLayout>
