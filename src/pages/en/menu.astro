---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header.astro';
import MenuSection from '../../components/sections/MenuSection.astro';
import Footer from '../../components/sections/Footer.astro';
import { safeGetMenu } from '../../lib/content';

const menuData = await safeGetMenu('en');
const categories = menuData.categories;
const allergenLegend = menuData.allergenLegend ?? [];
---

<BaseLayout
  lang="en"
  title="Menu — FRONT Valencia"
  description="Discover our menu: breakfasts, Vicente Patiño's tapas, grilled fish and meat, tray-baked rice and sweets."
>
  <Header lang="en" />
  <main id="main-content" class="pt-16">
    <MenuSection categories={categories} allergenLegend={allergenLegend} lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
