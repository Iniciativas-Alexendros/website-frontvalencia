---
interface Props {
  site: any;
  lang: 'es' | 'en';
}

const { site, lang } = Astro.props;

if (!site) return null;

// Build the Restaurant JSON-LD schema
const restaurant = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'FRONT',
  alternateName: 'FRONT The Terminal Bar',
  description: site.description ?? (lang === 'es'
    ? 'Restaurante y Terraza en La Marina de Valencia. Gastronomía mediterránea, brasas, arroces, música, cócteles y vistas.'
    : 'Restaurant & Terrace at La Marina de Valencia. Mediterranean cuisine, grills, rice, music, cocktails and views.'),
  url: lang === 'es' ? 'https://frontvalencia.com/es/' : 'https://frontvalencia.com/en/',
  image: site.ogImage ?? 'https://frontvalencia.com/foto-logo.jpg',
  telephone: site.contact?.phone ?? '+34 965 020 349',
  email: site.contact?.email ?? 'hello@frontvalencia.com',
  priceRange: '€€',
  servesCuisine: lang === 'es' ? ['Mediterránea', 'Española', 'Valenciana'] : ['Mediterranean', 'Spanish', 'Valencian'],
  acceptsReservations: 'true',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.location?.address ?? 'C/Travesía',
    addressLocality: site.location?.city ?? 'Valencia',
    postalCode: site.location?.postalCode ?? '46024',
    addressRegion: 'Valencia',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 39.4501,
    longitude: -0.3237,
  },
  hasMap: site.location?.mapsUrl ?? 'https://maps.app.goo.gl/FVnSVDYfv5XnNiU16',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday'],
      opens: '11:30',
      closes: '19:00',
    },
  ],
  sameAs: [
    site.social?.instagram,
    'https://front.feending.io/',
  ].filter(Boolean),
};

const json = JSON.stringify(restaurant);
---

<script type="application/ld+json" set:html={json} />
