{
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "overrides": [
    { "files": "*.json", "options": { "parser": "json" } },
    { "files": "*.md", "options": { "parser": "markdown" } }
  ]
}
