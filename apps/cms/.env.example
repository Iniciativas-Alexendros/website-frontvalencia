# =========================================================
# FRONT Valencia — Payload CMS Environment Variables
# =========================================================
# Copy this to `apps/cms/.env` and replace placeholders.
# Do NOT commit the real `.env` file.
# =========================================================

# ---------------------------------------
# DATABASE (Postgres)
# ---------------------------------------
DATABASE_URI=postgresql://frontvalencia:changeme@localhost:5432/frontvalencia

# ---------------------------------------
# PAYLOAD SECRETS
# ---------------------------------------
PAYLOAD_SECRET=replace_me_with_openssl_rand_base64_32
PAYLOAD_PREVIEW_SECRET=replace_me_with_the_same_secret_as_frontend

# ---------------------------------------
# PUBLIC URLS
# ---------------------------------------
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:4321

# ---------------------------------------
# CLOUDFLARE R2 (optional in dev)
# ---------------------------------------
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=frontvalencia-dev
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_PUBLIC_URL=https://pub-<bucket>.r2.dev
