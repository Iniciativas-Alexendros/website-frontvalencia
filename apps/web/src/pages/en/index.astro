---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import Hero from '../../components/sections/Hero';
import MenuSection from '../../components/sections/MenuSection';
import EspacioSection from '../../components/sections/EspacioSection';
import LocalizacionSection from '../../components/sections/LocalizacionSection';
import ReservasSection from '../../components/sections/ReservasSection';
import Footer from '../../components/sections/Footer';
import CookieConsent from '../../components/islands/CookieConsent';
import { safeGetMenu, safeGetSite } from '../../lib/content';

const menuData = await safeGetMenu('en');
const siteData = await safeGetSite();
const categories = menuData.categories;
const allergenLegend = menuData.allergenLegend ?? [];
---

<BaseLayout
  lang="en"
  title="FRONT | Restaurant & Terrace La Marina de Valencia"
  description="By the sea, next to the Port Clock, in the most brutalist building in Valencia. Mediterranean cuisine, grills, rice, music, cocktails and views."
>
  <Header lang="en" client:load site={siteData} />
  <main id="main-content">
    <Hero lang="en" />
    <MenuSection categories={categories} allergenLegend={allergenLegend} lang="en" />
    <EspacioSection lang="en" />
    <LocalizacionSection lang="en" site={siteData} />
    <ReservasSection lang="en" site={siteData} client:load />
  </main>
  <Footer lang="en" client:load />
  <CookieConsent lang="en" client:idle />
</BaseLayout>
