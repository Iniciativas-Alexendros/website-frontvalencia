---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import EspacioSection from '../../components/sections/EspacioSection';
import Footer from '../../components/sections/Footer';
import { safeGetSite } from '../../lib/content';

const siteData = await safeGetSite();
---

<BaseLayout
  lang="en"
  title="Space — FRONT Valencia"
  description="Dining by the sea, inside a brutalist gem. Covered terrace, lounge and cocktails bar at The Terminal Hub."
>
  <Header lang="en" client:load site={siteData} />
  <main id="main-content" class="pt-16">
    <EspacioSection lang="en" />
  </main>
  <Footer lang="en" client:load site={siteData} />
</BaseLayout>
