---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import ReservasSection from '../../components/sections/ReservasSection';
import Footer from '../../components/sections/Footer';
import { safeGetSite } from '../../lib/content';

const siteData = await safeGetSite();
---

<BaseLayout
  lang="en"
  title="Book — FRONT Valencia"
  description="Book your table at FRONT. Weekday lunch menu, full menu available daily and group menus."
>
  <Header lang="en" client:load site={siteData} />
  <main id="main-content" class="pt-16">
    <ReservasSection lang="en" site={siteData} />
  </main>
  <Footer lang="en" client:load site={siteData} />
</BaseLayout>
