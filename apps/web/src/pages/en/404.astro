---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import Footer from '../../components/sections/Footer';
---

<BaseLayout
  lang="en"
  title="Page not found — FRONT Valencia"
  description="The page you are looking for does not exist."
>
  <Header lang="en" />
  <main id="main-content" class="pt-16">
    <section class="min-h-[70vh] flex items-center justify-center px-4 py-20">
      <div class="text-center max-w-xl">
        <p class="text-xs uppercase tracking-[0.4em] text-terracotta-400 mb-6">Error 404</p>
        <h1 class="text-5xl sm:text-6xl font-black uppercase tracking-tight text-text-primary mb-6">Page not found</h1>
        <p class="text-text-secondary mb-10">The page you're looking for doesn't exist or has been moved. Go back to the home page or explore our sections.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/" class="inline-flex items-center justify-center px-8 py-3 bg-terracotta-500 hover:bg-terracotta-400 text-white font-semibold text-sm uppercase tracking-widest transition-colors">
            Go home
          </a>
          <a href="/en/menu" class="inline-flex items-center justify-center px-8 py-3 border border-concrete-600 hover:border-text-primary text-concrete-200 hover:text-text-primary font-semibold text-sm uppercase tracking-widest transition-colors">
            View menu
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</BaseLayout>
