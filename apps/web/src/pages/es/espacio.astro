---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import EspacioSection from '../../components/sections/EspacioSection';
import Footer from '../../components/sections/Footer';
import { safeGetSite } from '../../lib/content';

const siteData = await safeGetSite();
---

<BaseLayout
  lang="es"
  title="Espacio — FRONT Valencia"
  description="Comer frente al mar, dentro de una joya brutalista. Terraza cubierta, lounge y cocktails bar en The Terminal Hub."
>
  <Header lang="es" client:load site={siteData} />
  <main id="main-content" class="pt-16">
    <EspacioSection lang="es" />
  </main>
  <Footer lang="es" client:load site={siteData} />
</BaseLayout>
