---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import Hero from '../../components/sections/Hero';
import MenuSection from '../../components/sections/MenuSection';
import EspacioSection from '../../components/sections/EspacioSection';
import LocalizacionSection from '../../components/sections/LocalizacionSection';
import ReservasSection from '../../components/sections/ReservasSection';
import Footer from '../../components/sections/Footer';
import CookieConsent from '../../components/islands/CookieConsent';
import { safeGetMenu, safeGetSite } from '../../lib/content';

const menuData = await safeGetMenu('es');
const siteData = await safeGetSite();
const categories = menuData.categories;
const allergenLegend = menuData.allergenLegend ?? [];
---

<BaseLayout
  lang="es"
  title="FRONT | Restaurante y Terraza La Marina de Valencia"
  description="Frente al mar, junto al Reloj del Puerto, en el edificio más brutalista de Valencia. Gastronomía mediterránea, brasas, arroces, música, cócteles y vistas."
>
  <Header lang="es" client:load site={siteData} />
  <main id="main-content">
    <Hero lang="es" />
    <MenuSection categories={categories} allergenLegend={allergenLegend} lang="es" />
    <EspacioSection lang="es" />
    <LocalizacionSection lang="es" site={siteData} />
    <ReservasSection lang="es" site={siteData} client:load />
  </main>
  <Footer lang="es" client:load />
  <CookieConsent lang="es" client:idle />
</BaseLayout>
