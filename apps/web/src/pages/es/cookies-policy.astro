---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header';
import Footer from '../../components/sections/Footer';
import { safeGetSite } from '../../lib/content';

const siteData = await safeGetSite();
---

<BaseLayout
  lang="es"
  title="Política de Cookies — FRONT Valencia"
  description="Política de cookies y tecnologías de seguimiento de FRONT."
>
  <Header lang="es" client:load site={siteData} />
  <main id="main-content" class="pt-16">
    <section class="py-20 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-black uppercase tracking-tight text-text-primary mb-12">Política de Cookies</h1>

      <div class="space-y-8 text-text-secondary">
        <div>
          <h2 class="text-xl font-bold text-text-primary mb-3 uppercase tracking-wide">¿Qué son las cookies?</h2>
          <p>Las cookies son pequeños archivos de texto que un sitio web almacena en su dispositivo cuando lo visita. Permiten al sitio recordar sus acciones y preferencias durante un periodo determinado.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-text-primary mb-3 uppercase tracking-wide">Tipos de cookies que utilizamos</h2>
          <ul class="space-y-2">
            <li><strong class="text-text-primary">Técnicas (necesarias):</strong> Imprescindibles para el funcionamiento del sitio web y la gestión de reservas.</li>
            <li><strong class="text-text-primary">Analíticas:</strong> Nos permiten medir y analizar la navegación (Metricool, con consentimiento previo).</li>
            <li><strong class="text-text-primary">Marketing:</strong> Para mostrar publicidad personalizada (Meta Pixel, con consentimiento previo).</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-bold text-text-primary mb-3 uppercase tracking-wide">Gestión del consentimiento</h2>
          <p>Puede aceptar, rechazar o configurar el uso de cookies a través del banner que aparece al acceder al sitio web, o en cualquier momento contactando con hello@frontvalencia.com.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-text-primary mb-3 uppercase tracking-wide">Terceros</h2>
          <p>Los principales terceros que pueden instalar cookies son CoverManager (reservas), Metricool (analítica) y Meta (publicidad).</p>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="es" client:load />
</BaseLayout>
