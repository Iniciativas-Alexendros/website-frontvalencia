---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import '../styles/tokens.css';
import '../styles/fonts.css';
import StructuredData from '../components/seo/StructuredData.tsx';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
  image?: string;
  canonical?: string;
}

const {
  title,
  description,
  image = '/og-image.svg',
  canonical,
  lang,
} = Astro.props;

const path = Astro.url.pathname
const page = path.match(/carta|menu/) ? 'menu'
  : path.match(/espacio|space/) ? 'space'
  : path.match(/localizacion|location/) ? 'location'
  : path.match(/reservas|book/) ? 'book'
  : 'home'

const alternateEs = Astro.url.pathname.replace(/^\/en/, '/es') || '/es/';
const alternateEn = Astro.url.pathname.replace(/^\/es/, '/en') || '/en/';

const isHomePage = page === 'home'
const reservesHref = lang === 'es' ? '/es/#reservas' : '/en/#book'
const reservesLabel = lang === 'es' ? 'Reserva ahora tu mesa' : 'Book your table now'
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_ES'} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="theme-color" content="#d4634a" />
    <meta name="msapplication-TileColor" content="#d4634a" />

    <link rel="canonical" href={canonical || Astro.url.href} />
    <link rel="alternate" hreflang="es" href={new URL(alternateEs, Astro.site).href} />
    <link rel="alternate" hreflang="en" href={new URL(alternateEn, Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/es/', Astro.site).href} />
    <!-- Critical font preload for LCP headings -->
    <link rel="preload" as="font" href="/fonts/Geist-Bold.woff2" type="font/woff2" crossorigin="anonymous" />
    <ClientRouter />
    <title>{title}</title>
    <StructuredData lang={lang} page={page} />
    <Analytics />
    <script>
      import('../lib/telemetry.ts');
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-100 focus:bg-terracotta-500 focus:text-white focus:px-4 focus:py-2">
      {lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}
    </a>
    {isHomePage && (
      <a
        href={reservesHref}
        class="fixed top-4 right-4 z-50 bg-terracotta-500 hover:bg-terracotta-400 text-white px-4 py-2 rounded font-semibold opacity-0 pointer-events-none transition-opacity duration-300"
        id="sticky-reservas-btn"
        aria-label={reservesLabel}
      >
        {reservesLabel}
      </a>
    )}
    <slot />
    <script is:inline>
      // Sticky reservas button visibility after scroll > 100px
      const stickyBtn = document.getElementById('sticky-reservas-btn')
      if (stickyBtn) {
        const toggleSticky = () => {
          if (window.scrollY > 100) {
            stickyBtn.classList.remove('opacity-0', 'pointer-events-none')
            stickyBtn.classList.add('opacity-100')
          } else {
            stickyBtn.classList.add('opacity-0', 'pointer-events-none')
            stickyBtn.classList.remove('opacity-100')
          }
        }
        window.addEventListener('scroll', toggleSticky, { passive: true })
        toggleSticky()
      }
      // Scroll reveal via IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
