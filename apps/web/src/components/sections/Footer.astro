---
import { safeGetSite } from '../../lib/content';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const site = await safeGetSite();

const t = lang === 'es'
  ? {
      contact: 'Contacto',
      legal: 'Legal',
      social: 'Síguenos',
      careers: 'Talento',
      legalAdvice: 'Aviso Legal',
      privacy: 'Privacidad',
      cookies: 'Cookies',
      copyright: `© ${new Date().getFullYear()} FRONT THE TERMINAL BAR. Todos los derechos reservados.`,
      newsletter: 'Suscríbete para enterarte de todo',
      email: 'Email',
      subscribe: 'Suscribirse',
      thanks: '¡Gracias!',
      addressLabel: 'Dirección',
      phoneLabel: 'Teléfono',
      emailLabel: 'Email',
    }
  : {
      contact: 'Contact',
      legal: 'Legal',
      social: 'Follow us',
      careers: 'Careers',
      legalAdvice: 'Legal Notice',
      privacy: 'Privacy',
      cookies: 'Cookies',
      copyright: `© ${new Date().getFullYear()} FRONT THE TERMINAL BAR. All rights reserved.`,
      newsletter: 'Subscribe to stay updated',
      email: 'Email',
      subscribe: 'Subscribe',
      thanks: 'Thanks!',
      addressLabel: 'Address',
      phoneLabel: 'Phone',
      emailLabel: 'Email',
    };

const phone = site?.contact?.phone ?? '+34 965 020 349';
const phoneClean = (site?.contact?.whatsapp ?? '34965020349').replace(/\D/g, '');
const email = site?.contact?.email ?? 'hello@frontvalencia.com';
const eventsEmail = site?.contact?.eventsEmail ?? 'eventos@frontvalencia.com';
const reservationsEmail = site?.contact?.reservationsEmail ?? 'reservas@frontvalencia.com';
const address = site?.location?.address ?? 'C/Travesía';
const city = site?.location?.city ?? 'Valencia';
const postal = site?.location?.postalCode ?? '46024';
const area = site?.location?.area ?? 'La Marina de Valencia';
const instagram = site?.social?.instagram ?? 'https://www.instagram.com/frontvalencia';
const careers = site?.externalLinks?.careers ?? 'https://grupoelalto-1738067471.teamtailor.com/';
---

<footer class="bg-concrete-950 border-t border-concrete-800 py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Logo + Newsletter -->
      <div>
        <img src="/images/logos/LOGO_MV_SVG.svg" alt="FRONT" width="120" height="40" class="h-10 w-auto mb-6" loading="lazy" decoding="async" />
        <p class="text-sm text-text-muted mb-4">{t.newsletter}</p>
        <form id="newsletter-form" class="flex gap-2">
          <label for="newsletter-email" class="sr-only">{t.email}</label>
          <input
            id="newsletter-email"
            name="email"
            type="email"
            placeholder="email@example.com"
            class="flex-1 min-w-0 bg-concrete-900 border border-concrete-700 px-3 py-2 text-sm text-text-primary placeholder-concrete-500 focus:border-terracotta-400 focus:outline-none transition-colors"
            required
            autocomplete="email"
          />
          <button
            type="submit"
            class="bg-terracotta-500 hover:bg-terracotta-400 text-white px-4 py-2 text-sm font-semibold uppercase tracking-wider transition-colors shrink-0"
          >
            <span id="newsletter-btn-label">{t.subscribe}</span>
          </button>
        </form>
        <p id="newsletter-feedback" class="mt-2 text-xs text-terracotta-400 hidden" role="status" aria-live="polite">{t.thanks}</p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-text-primary mb-4">{t.contact}</h3>
        <ul class="space-y-2.5 text-sm text-text-secondary">
          <li>
            <span class="text-text-muted text-xs uppercase tracking-wider block">{t.addressLabel}</span>
            {address}<br />{postal} — {area}, {city}
          </li>
          <li>
            <span class="text-text-muted text-xs uppercase tracking-wider block">{t.phoneLabel}</span>
            <a href={`tel:${phoneClean}`} class="hover:text-terracotta-400 transition-colors">{phone}</a>
          </li>
          <li>
            <span class="text-text-muted text-xs uppercase tracking-wider block">{t.emailLabel}</span>
            <a href={`mailto:${email}`} class="hover:text-terracotta-400 transition-colors">{email}</a>
          </li>
          <li class="pt-2 border-t border-concrete-800">
            <a href={`mailto:${reservationsEmail}`} class="hover:text-terracotta-400 transition-colors text-xs">{reservationsEmail}</a><br />
            <a href={`mailto:${eventsEmail}`} class="hover:text-terracotta-400 transition-colors text-xs">{eventsEmail}</a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-text-primary mb-4">{t.legal}</h3>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li><a href={lang === 'es' ? '/es/legal-advice' : '/en/legal-advice'} class="hover:text-terracotta-400 transition-colors">{t.legalAdvice}</a></li>
          <li><a href={lang === 'es' ? '/es/privacy-policy' : '/en/privacy-policy'} class="hover:text-terracotta-400 transition-colors">{t.privacy}</a></li>
          <li><a href={lang === 'es' ? '/es/cookies-policy' : '/en/cookies-policy'} class="hover:text-terracotta-400 transition-colors">{t.cookies}</a></li>
          <li>
            <a href={careers} target="_blank" rel="noopener noreferrer" class="hover:text-terracotta-400 transition-colors flex items-center gap-1">
              {t.careers}
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-text-primary mb-4">{t.social}</h3>
        <a
          href={instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-terracotta-400 transition-colors"
          aria-label="Instagram"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          @frontvalencia
        </a>
      </div>
    </div>

    <div class="border-t border-concrete-800 pt-8 text-center">
      <p class="text-xs text-text-muted tracking-wider">{t.copyright}</p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const feedback = document.getElementById('newsletter-feedback');
  const btnLabel = document.getElementById('newsletter-btn-label');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!feedback || !btnLabel) return;
    const input = form.querySelector<HTMLInputElement>('#newsletter-email');
    if (!input || !input.value) return;
    // TODO: Replace with real endpoint (e.g. Mailchimp, ConvertKit)
    console.info('[newsletter] subscribe request:', input.value);
    feedback.classList.remove('hidden');
    btnLabel.textContent = feedback.textContent ?? '✓';
    input.value = '';
    setTimeout(() => {
      feedback.classList.add('hidden');
      if (btnLabel) btnLabel.textContent = form.dataset.originalLabel ?? btnLabel.textContent ?? '';
    }, 3000);
  });
</script>
