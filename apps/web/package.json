{
  "name": "frontvalencia-web",
  "version": "1.0.4",
  "type": "module",
  "description": "Frontend de Front Valencia - Astro + React + Tailwind",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "menu:generate": "astro build && node scripts/generate-menu-pdf.mjs",
    "dev": "astro dev --host",
    "lint": "astro check",
    "preview": "astro preview",
    "scrape": "npx tsx scripts/scrape-content.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "content:pull": "payload migrate",
    "content:seed": "payload migrate:seed"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.7.0",
    "geist": "^1.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/partytown": "^2.1.0",
    "@astrojs/prefetch": "^0.4.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.3.0",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
